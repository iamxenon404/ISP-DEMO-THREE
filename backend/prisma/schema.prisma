generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  admin
  support
  technician
}

enum UserStatus {
  pending
  active
  suspended
}

enum TicketStatus {
  open
  ai_handling
  waiting_human
  in_progress
  resolved
  closed
}

enum SenderType {
  customer
  ai
  support
}

enum SubscriptionStatus {
  active
  suspended
  expired
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum InstallationStatus {
  pending
  assigned
  in_progress
  completed
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(customer)
  status        UserStatus     @default(pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscription  Subscription?
  tickets       Ticket[]
  messages      Message[]
  
  // Relations for Installation
  installations Installation[] @relation("CustomerInstallations")
  assignedJobs  Installation[] @relation("TechnicianJobs")

  @@map("users")
}

model Plan {
  id            Int            @id @default(autoincrement())
  name          String
  speed         Int
  price         Float
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id         Int                @id @default(autoincrement())
  userId     Int                @unique
  planId     Int
  status     SubscriptionStatus @default(active)
  expiryDate DateTime
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id          Int           @id @default(autoincrement())
  userId      Int
  amount      Float
  status      PaymentStatus @default(completed)
  description String?
  createdAt   DateTime      @default(now())

  @@map("payments")
}

model Ticket {
  id        Int          @id @default(autoincrement())
  userId    Int
  subject   String
  status    TicketStatus @default(ai_handling)
  waitTime  Int?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("tickets")
}

model Message {
  id         Int        @id @default(autoincrement())
  ticketId   Int
  senderId   Int?
  senderType SenderType @default(customer)
  content    String
  createdAt  DateTime   @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Installation {
  id           Int                @id @default(autoincrement())
  userId       Int
  technicianId Int?
  status       InstallationStatus @default(pending)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Named relations to the User model
  user       User  @relation("CustomerInstallations", fields: [userId], references: [id], onDelete: Cascade)
  technician User? @relation("TechnicianJobs", fields: [technicianId], references: [id])

  @@map("installations")
}