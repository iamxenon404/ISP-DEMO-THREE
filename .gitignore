# ── Dependencies ────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables ────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Build outputs ────────────────────────────
dist/
build/
.next/
out/

# ── Prisma ───────────────────────────────────
