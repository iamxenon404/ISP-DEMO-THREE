backend/node_modules/.prisma/
backend/generated/

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS files ─────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ──────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Misc ─────────────────────────────────────
*.tsbuildinfo
.cache/
.parcel-cache/
.turbo/